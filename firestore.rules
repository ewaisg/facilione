rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return getUserDoc().role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isCM() {
      return hasRole('cm');
    }

    function isPM() {
      return hasRole('pm');
    }

    function isInOrg(resourceOrgId) {
      return getUserDoc().orgId == resourceOrgId;
    }

    function isAssignedPM(projectData) {
      return request.auth.uid == projectData.pmUserId;
    }

    function isManagingCM(projectData) {
      return isCM() && projectData.pmUserId in getUserDoc().managedUserIds;
    }

    function canAccessLinkedProject(projectId) {
      let proj = get(/databases/$(database)/documents/projects/$(projectId)).data;
      return isAdmin()
             || isAssignedPM(proj)
             || isManagingCM(proj);
    }

    // ─── User Documents ─────────────────────────────────────────

    match /users/{userId} {
      allow read: if request.auth.uid == userId
                  || isAdmin()
                  || (isCM() && userId in getUserDoc().managedUserIds);
      allow write: if isAdmin();
    }

    // ─── Organization Documents ─────────────────────────────────

    match /organizations/{orgId} {
      allow read: if request.auth != null && isInOrg(orgId);
      allow write: if isAdmin() && isInOrg(orgId);
    }

    // ─── Customization Documents ────────────────────────────────

    match /customization/{orgId}/{document=**} {
      allow read: if request.auth != null && isInOrg(orgId);
      allow write: if isAdmin() && isInOrg(orgId);
    }

    // ─── Project Documents ──────────────────────────────────────

    match /projects/{projectId} {
      allow read: if isAdmin()
                  || isAssignedPM(resource.data)
                  || isManagingCM(resource.data);

      allow create: if isAdmin() || isPM() || isCM();

      allow update: if isAdmin()
                    || isAssignedPM(resource.data)
                    || isManagingCM(resource.data);

      allow delete: if isAdmin();

      // ─── Project Sub-Collections ────────────────────────────

      match /{subcollection}/{docId} {
        allow read: if isAdmin()
                    || isAssignedPM(
                         get(/databases/$(database)/documents/projects/$(projectId)).data)
                    || isManagingCM(
                         get(/databases/$(database)/documents/projects/$(projectId)).data);

        allow write: if isAdmin()
                     || isAssignedPM(
                          get(/databases/$(database)/documents/projects/$(projectId)).data)
                     || isManagingCM(
                          get(/databases/$(database)/documents/projects/$(projectId)).data);
      }
    }

    // ─── Knowledge Base ─────────────────────────────────────────

    match /kb/{collection}/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ─── AI Sessions ────────────────────────────────────────────

    match /ai-sessions/{sessionId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.userId || isAdmin());
      allow write: if request.auth != null
                   && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;

      match /messages/{messageId} {
        allow read, write: if request.auth != null
                           && (request.auth.uid == get(
                                /databases/$(database)/documents/ai-sessions/$(sessionId)
                              ).data.userId || isAdmin());
      }
    }

    // ─── Import Logs ────────────────────────────────────────────

    match /imports/{importId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // ─── Notifications ──────────────────────────────────────────

    match /notifications/{notificationId} {
      allow read: if request.auth != null
                  && request.auth.uid == resource.data.userId;
      allow create: if isAdmin();
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.userId;
      allow delete: if isAdmin();
    }

    // ─── Estimates (Phase 1.5) ──────────────────────────────────

    match /estimates/{estimateId} {
      allow read: if isAdmin()
                  || request.auth.uid == resource.data.userId
                  || (resource.data.projectId != null
                      && isAssignedPM(
                           get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data));

      allow create: if request.auth != null;

      allow update: if isAdmin()
                    || request.auth.uid == resource.data.userId;

      allow delete: if isAdmin()
                    || request.auth.uid == resource.data.userId;
    }

    // ─── User Preferences (Phase 1.5) ───────────────────────────

    match /userPreferences/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // ─── Cost Reviews (PM Cost Review Smart Tool) ─────────────────

    match /costReviews/{costReviewId} {
      allow read: if isAdmin()
                  || isAssignedPM(
                       get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data)
                  || isManagingCM(
                       get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data);

      allow create: if isAdmin()
                    || isPM()
                    || isCM();

      allow update: if isAdmin()
                    || isAssignedPM(
                         get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data)
                    || isManagingCM(
                         get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data);

      allow delete: if isAdmin();
    }

    // ─── Cost Review Imports ────────────────────────────────────

    match /costReviewImports/{importId} {
      allow read: if isAdmin()
                  || isAssignedPM(
                       get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data)
                  || isManagingCM(
                       get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data);

      allow create: if isAdmin()
                    || isPM()
                    || isCM();

      allow update: if isAdmin();

      allow delete: if isAdmin();
    }

    // ─── Cost Review User Inputs ────────────────────────────────

    match /costReviewInputs/{costReviewId} {
      allow read: if isAdmin()
                  || isAssignedPM(
                       get(/databases/$(database)/documents/costReviews/$(costReviewId)).data)
                  || isManagingCM(
                       get(/databases/$(database)/documents/costReviews/$(costReviewId)).data);

      allow write: if isAdmin()
                   || isAssignedPM(
                        get(/databases/$(database)/documents/costReviews/$(costReviewId)).data)
                   || isManagingCM(
                        get(/databases/$(database)/documents/costReviews/$(costReviewId)).data);
    }

    // ─── Cost Review Settings (Admin only) ──────────────────────

    match /costReviewSettings/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ─── SiteFolio Sessions (Admin read, server write only) ─────

    match /sitefolio_sessions/{docId} {
      allow read: if isAdmin();
      allow write: if false; // Written by Firebase Admin SDK only
    }

    // ─── Portfolio AI Cache (User-specific dashboard cache) ─────

    match /portfolioAiCache/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // ─── User Sessions (Active device sessions) ─────

    match /userSessions/{sessionId} {
      allow read: if request.auth != null
                  && request.auth.uid == resource.data.userId;
      allow write: if request.auth != null
                   && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.userId;
      allow read: if isAdmin();
    }

    // ─── Task Projects (Task management) ─────

    match /taskProjects/{projectId} {
      allow read: if request.auth != null
                  && (isAdmin()
                      || request.auth.uid == resource.data.createdBy
                      || (resource.data.linkedProjectId != null
                          && canAccessLinkedProject(resource.data.linkedProjectId)));

      allow create: if request.auth != null;

      allow update: if request.auth != null
                    && (isAdmin()
                        || request.auth.uid == resource.data.createdBy);

      allow delete: if request.auth != null
                    && (isAdmin()
                        || request.auth.uid == resource.data.createdBy);

      // Sections subcollection
      match /sections/{sectionId} {
        allow read, write: if request.auth != null
                           && (isAdmin()
                               || request.auth.uid == get(/databases/$(database)/documents/taskProjects/$(projectId)).data.createdBy);

        // Tasks subcollection
        match /tasks/{taskId} {
          allow read, write: if request.auth != null
                             && (isAdmin()
                                 || request.auth.uid == get(/databases/$(database)/documents/taskProjects/$(projectId)).data.createdBy);
        }
      }

      // Next steps subcollection
      match /nextSteps/{stepId} {
        allow read, write: if request.auth != null
                           && (isAdmin()
                               || request.auth.uid == get(/databases/$(database)/documents/taskProjects/$(projectId)).data.createdBy);
      }
    }
  }
}
