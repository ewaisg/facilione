rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function canAccessProject(projectId) {
      let user = getUserDoc();
      let project = firestore.get(/databases/(default)/documents/projects/$(projectId)).data;
      return user.role == 'admin'
             || request.auth.uid == project.pmUserId
             || (user.role == 'cm' && project.pmUserId in user.managedUserIds);
    }

    function isAdminInOrg(orgId) {
      let user = getUserDoc();
      return user.role == 'admin' && user.orgId == orgId;
    }

    // Project documents — up to 50MB
    match /projects/{projectId}/{allPaths=**} {
      allow read: if isSignedIn() && canAccessProject(projectId);
      allow create, update: if isSignedIn()
                            && canAccessProject(projectId)
                            && request.resource.size < 50 * 1024 * 1024;
      allow delete: if isSignedIn() && canAccessProject(projectId);
    }

    // Knowledge base files — read-only for clients (admin SDK writes)
    match /kb/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Organization assets (logos, favicons) — up to 5MB
    match /organizations/{orgId}/{allPaths=**} {
      allow read: if isSignedIn() && getUserDoc().orgId == orgId;
      allow create, update: if isSignedIn()
                            && isAdminInOrg(orgId)
                            && request.resource.size < 5 * 1024 * 1024;
      allow delete: if isSignedIn() && isAdminInOrg(orgId);
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
